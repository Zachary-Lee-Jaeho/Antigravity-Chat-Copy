{
  "name": "antigravity-chat-copy",
  "displayName": "Antigravity Chat Copy",
  "description": "Copy markdown originals from Antigravity chat conversations",
  "version": "2.1.0",
  "publisher": "zachary-lee-jaeho",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zachary-Lee-Jaeho/Antigravity-Chat-Copy.git"
  },
  "engines": {
    "vscode": "^1.68.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chatCopy",
          "title": "Chat Copy",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "chatCopy": [
        {
          "id": "chatCopy.conversations",
          "name": "Conversations"
        }
      ]
    },
    "commands": [
      {
        "command": "antigravityChatCopy.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "antigravityChatCopy.openConversation",
        "title": "Open Conversation"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "antigravityChatCopy.refresh",
          "when": "view == chatCopy.conversations",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "chatCopy.conversations.focus",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "configuration": {
      "title": "Antigravity Chat Copy",
      "properties": {
        "antigravityChatCopy.allowInsecureTls": {
          "type": "boolean",
          "default": false,
          "description": "Allow insecure localhost TLS when cert.pem pinning fails (NOT recommended)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.68.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}